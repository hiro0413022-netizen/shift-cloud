# ============================================================
# .dev.vars - ローカル開発用環境変数
# このファイルを .dev.vars にコピーして値を設定してください
# ※ .dev.vars は .gitignore に含まれています（コミット禁止）
# ============================================================

# 認証設定
AUTH_SECRET=your-secret-key-change-this
AUTH_USERNAME=admin
AUTH_PASSWORD=your-password-here

# システム名（ナビバー・ログインページ・タイトルに表示）
APP_NAME=発注管理システム

# メール署名情報（メール下書き・発注メールの署名に使用）
APP_SENDER_NAME=山田 太郎        # 例: ゴルフウィング宝塚店の古川
APP_SENDER_SHOP=○○店            # 例: GOLF WING 宝塚店
APP_SENDER_ADDR=〒000-0000 ○○県○○市○○1-2-3  # 住所
APP_SENDER_TEL=000-000-0000      # 電話番号
APP_SENDER_MAIL=info@example.com # メールアドレス

# CC アドレス（メール送信時のデフォルトCC、セミコロン区切り）
APP_DEFAULT_CC=user1@example.com;user2@example.com

# デモモード（"1" に設定するとログイン不要・書き込み禁止になります）
# DEMO_MODE=1
